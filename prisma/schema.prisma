generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int             @id @default(autoincrement())
  username      String          @unique
  password      String
  status        String          @default("A") @db.VarChar(50)
  employeeId    Int
  employee      Employee        @relation(fields: [employeeId], references: [id])
  roleId        Int
  role          Role            @relation(fields: [roleId], references: [id])
  provinceId    Int?
  province      Province?       @relation(fields: [provinceId], references: [id])
  districtId    Int?
  district      District?       @relation(fields: [districtId], references: [id])
  createdAt     DateTime        @default(now()) @db.Timestamptz(0)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(0)
  fcmtokens     FcmToken[]
  turnoffDocs   TurnoffDoc[]
  emergencyDocs EmergencyDoc[]
  problemtypes  ProblemType[]
  userReceiver  ProblemAssign[] @relation("UserReceiver")
  userActive    ProblemAssign[] @relation("UserActive")
}

model FcmToken {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id])
  platform String @db.VarChar(255)
  model    String @db.VarChar(255)
  fcmtoken String @db.VarChar(255)

  @@unique([userId, platform, model])
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String? @db.VarChar(255)
  users       User[]
}

model Employee {
  id           Int         @id
  first_name   String      @db.VarChar(255)
  last_name    String      @db.VarChar(255)
  emp_code     String      @unique @db.VarChar(255)
  status       String      @default("A") @db.VarChar(50)
  gender       String?     @db.VarChar(255)
  tel          String?     @db.VarChar(255)
  email        String?     @db.VarChar(255)
  empimg       String?     @db.VarChar(255)
  posId        Int?
  position     Position?   @relation(fields: [posId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  divisionId   Int?
  division     Division?   @relation(fields: [divisionId], references: [id])
  officeId     Int?
  office       Office?     @relation(fields: [officeId], references: [id])
  unitId       Int?
  unit         Unit?       @relation(fields: [unitId], references: [id])
  createdAt    DateTime    @default(now()) @db.Timestamptz(0)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(0)
  user         User[]
}

model Department {
  id                Int        @id
  department_name   String?    @db.VarChar(255)
  department_code   String?    @db.VarChar(50)
  department_status String     @default("A") @db.VarChar(50)
  divisions         Division[]
  employees         Employee[]
}

model Division {
  id              Int        @id
  division_name   String?    @db.VarChar(255)
  division_code   String?    @db.VarChar(50)
  division_status String     @default("A") @db.VarChar(50)
  branch_id       Int?
  short_name      String?    @db.VarChar(255)
  insur_code      String?    @db.VarChar(255)
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  offices         Office[]
  units           Unit[]
  employees       Employee[]
}

model Office {
  id            Int        @id
  office_name   String?    @db.VarChar(255)
  office_code   String?    @db.VarChar(50)
  office_status String     @default("A") @db.VarChar(50)
  divisionId    Int?
  division      Division?  @relation(fields: [divisionId], references: [id])
  units         Unit[]
  employees     Employee[]
}

model Unit {
  id          Int        @id
  unit_name   String?    @db.VarChar(255)
  unit_code   String?    @db.VarChar(50)
  unit_status String     @default("A") @db.VarChar(50)
  unit_type   String?    @db.VarChar(50)
  divisionId  Int?
  division    Division?  @relation(fields: [divisionId], references: [id])
  officeId    Int?
  office      Office?    @relation(fields: [officeId], references: [id])
  employees   Employee[]
}

model PositionGroup {
  id             Int            @id
  pos_group_name String         @db.VarChar(255)
  positioncodes  PositionCode[]
}

model PositionCode {
  id              Int            @id
  pos_code_name   String         @db.VarChar(255)
  pos_code_status String         @default("A") @db.VarChar(50)
  posgroupId      Int?
  positiongroup   PositionGroup? @relation(fields: [posgroupId], references: [id])
  positions       Position[]
}

model Position {
  id           Int           @id
  pos_name     String        @db.VarChar(255)
  pos_status   String        @default("A") @db.VarChar(50)
  poscodeId    Int?
  positioncode PositionCode? @relation(fields: [poscodeId], references: [id])
  employees    Employee[]
}

model Province {
  id             Int            @id
  province_name  String         @db.VarChar(255)
  province_code  String         @unique @db.VarChar(255)
  province_short String         @db.VarChar(50)
  branch_code    String         @db.VarChar(50)
  districts      District[]
  users          User[]
  turnoffDocs    TurnoffDoc[]
  emergencyDocs  EmergencyDoc[]
  problemDocs    ProblemDoc[]
}

model District {
  id            Int            @id
  provinceCode  String
  province      Province       @relation(fields: [provinceCode], references: [province_code])
  district_name String         @db.VarChar(255)
  district_code String         @unique @db.VarChar(50)
  villages      Village[]
  users         User[]
  turnoffDocs   TurnoffDoc[]
  emergencyDocs EmergencyDoc[]
  problemDocs   ProblemDoc[]
}

model Village {
  id                 Int                @id
  districtCode       String
  district           District           @relation(fields: [districtCode], references: [district_code])
  village_name       String             @db.VarChar(255)
  village_code       String?            @db.VarChar(50)
  turnoffAddresses   TurnoffAddress[]
  emergencyAddresses EmergencyAddress[]
  problemDocs        ProblemDoc[]
}

model TurnoffDoc {
  id               Int              @id @default(autoincrement())
  title            String           @db.VarChar(255)
  description      String?          @db.Text
  startDate        DateTime         @db.Timestamptz(0)
  endDate          DateTime         @db.Timestamptz(0)
  startTime        String           @db.VarChar(50)
  endTime          String           @db.VarChar(50)
  turnoffFile      String           @db.VarChar(255)
  provinceId       Int?
  province         Province?        @relation(fields: [provinceId], references: [id])
  districtId       Int?
  district         District?        @relation(fields: [districtId], references: [id])
  createdById      Int
  createdBy        User             @relation(fields: [createdById], references: [id])
  createdAt        DateTime         @default(now()) @db.Timestamptz(0)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(0)
  turnoffAddresses TurnoffAddress[]
  turnoffAssigns   TurnoffAssign[]

  @@index([createdById])
  @@index([provinceId])
  @@index([districtId])
}

model TurnoffAddress {
  id        Int        @id @default(autoincrement())
  turnoffId Int
  turnoff   TurnoffDoc @relation(fields: [turnoffId], references: [id])
  villageId Int
  village   Village    @relation(fields: [villageId], references: [id])
  createdAt DateTime   @default(now()) @db.Timestamptz(0)
  updatedAt DateTime   @updatedAt @db.Timestamptz(0)

  @@index([turnoffId])
}

model TurnoffAssign {
  id        Int        @id @default(autoincrement())
  turnoffId Int
  turnoff   TurnoffDoc @relation(fields: [turnoffId], references: [id])
  userAppId Int
  docview   Boolean    @default(false) // true = view , false = pending
  createdAt DateTime   @default(now()) @db.Timestamptz(0)
  updatedAt DateTime   @updatedAt @db.Timestamptz(0)

  @@index([turnoffId])
  @@index([userAppId])
}

model EmergencyDoc {
  id                 Int                @id @default(autoincrement())
  title              String             @db.VarChar(255)
  description        String?            @db.Text
  emergencyDate      DateTime           @db.Timestamptz(0)
  startTime          String             @db.VarChar(50)
  endTime            String             @db.VarChar(50)
  lat                Float
  lng                Float
  emergencyImg       String             @db.VarChar(255)
  provinceId         Int?
  province           Province?          @relation(fields: [provinceId], references: [id])
  districtId         Int?
  district           District?          @relation(fields: [districtId], references: [id])
  createdById        Int
  createdBy          User               @relation(fields: [createdById], references: [id])
  createdAt          DateTime           @default(now()) @db.Timestamptz(0)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(0)
  emergencyAddresses EmergencyAddress[]
  emergencyAssigns   EmergencyAssign[]

  @@index([createdById])
  @@index([provinceId])
  @@index([districtId])
}

model EmergencyAddress {
  id          Int          @id @default(autoincrement())
  emergencyId Int
  emergency   EmergencyDoc @relation(fields: [emergencyId], references: [id])
  villageId   Int
  village     Village      @relation(fields: [villageId], references: [id])
  createdAt   DateTime     @default(now()) @db.Timestamptz(0)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(0)

  @@index([emergencyId])
}

model EmergencyAssign {
  id          Int          @id @default(autoincrement())
  emergencyId Int
  emergency   EmergencyDoc @relation(fields: [emergencyId], references: [id])
  userAppId   Int
  docview     Boolean      @default(false) // true = view , false = pending
  createdAt   DateTime     @default(now()) @db.Timestamptz(0)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(0)

  @@index([emergencyId])
  @@index([userAppId])
}

model SourceType {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(255)
  description String?      @db.VarChar(255)
  problemdocs ProblemDoc[]
}

model ProblemType {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(255)
  code        String?      @db.VarChar(255)
  createdById Int
  createdBy   User         @relation(fields: [createdById], references: [id])
  createdAt   DateTime     @default(now()) @db.Timestamptz(0)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(0)
  problemdocs ProblemDoc[]
}

model ProblemStatus {
  id          Int          @id @default(autoincrement())
  name        String       @db.VarChar(255)
  problemdocs ProblemDoc[]
}

model ProblemDoc {
  id              Int            @id @default(autoincrement())
  problemtypeId   Int
  problemtype     ProblemType    @relation(fields: [problemtypeId], references: [id])
  fullName        String         @db.VarChar(255)
  description     String?        @db.VarChar(255)
  tel             String         @db.VarChar(255)
  lat             Float
  lng             Float
  problemImg      String?        @db.VarChar(255)
  provinceId      Int
  province        Province       @relation(fields: [provinceId], references: [id])
  districtId      Int
  district        District       @relation(fields: [districtId], references: [id])
  villageId       Int
  village         Village        @relation(fields: [villageId], references: [id])
  problemstatusId Int            @default(1)
  problemstatus   ProblemStatus  @relation(fields: [problemstatusId], references: [id])
  sourcetypeId    Int
  sourcetype      SourceType     @relation(fields: [sourcetypeId], references: [id])
  createdById     Int
  createdAt       DateTime       @default(now()) @db.Timestamptz(0)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(0)
  problemAssigns  ProblemAssign?

  @@index([problemtypeId])
  @@index([problemstatusId])
  @@index([sourcetypeId])
}

model ProblemAssign {
  id             Int        @id @default(autoincrement())
  problemId      Int        @unique
  problem        ProblemDoc @relation(fields: [problemId], references: [id])
  userReceiverId Int?
  userReceiver   User?      @relation("UserReceiver", fields: [userReceiverId], references: [id])
  userActiveId   Int?
  userActive     User?      @relation("UserActive", fields: [userActiveId], references: [id])
  commentText    String?    @db.VarChar(255)
  commentAudio   String?    @db.VarChar(255)
  commentImg     String?    @db.VarChar(255)
  createdAt      DateTime   @default(now()) @db.Timestamptz(0)
  updatedAt      DateTime   @updatedAt @db.Timestamptz(0)

  @@index([problemId])
}
