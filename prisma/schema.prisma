generator client {
  provider               = "prisma-client"
  output                 = "../generated/prisma"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = "js"
}

datasource db {
  provider = "postgresql"
}

model ExternalUser {
  id            Int            @id
  name          String?        @db.VarChar(255)
  tel           String?        @db.VarChar(255)
  conversations Conversation[]
  messages      Message[]
}

model User {
  id            Int               @id @default(autoincrement())
  username      String            @unique
  password      String
  status        String            @default("A") @db.VarChar(50)
  employeeId    Int               @unique
  employee      Employee          @relation(fields: [employeeId], references: [id])
  roleId        Int
  role          Role              @relation(fields: [roleId], references: [id])
  provinceId    Int?
  province      Province?         @relation(fields: [provinceId], references: [id])
  districtId    Int?
  district      District?         @relation(fields: [districtId], references: [id])
  createdAt     DateTime          @default(now()) @db.Timestamptz(0)
  updatedAt     DateTime          @updatedAt @db.Timestamptz(0)
  fcmtokens     FcmToken[]
  turnoffDocs   TurnoffDoc[]
  emergencyDocs EmergencyDoc[]
  cutpowerDocs  CutpowerDoc[]
  topics        Topic[]
  userCalls     UserAcceptMeter[] @relation("userCall")
  userProvinces UserAcceptMeter[] @relation("userProvince")
  messages      Message[]
}

model FcmToken {
  id       Int    @id @default(autoincrement())
  userId   Int
  user     User   @relation(fields: [userId], references: [id])
  platform String @db.VarChar(255)
  model    String @db.VarChar(255)
  fcmtoken String @db.VarChar(255)

  @@unique([userId, platform, model])
}

model Role {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String? @db.VarChar(255)
  users       User[]
}

model Employee {
  id           Int         @id
  first_name   String      @db.VarChar(255)
  last_name    String      @db.VarChar(255)
  emp_code     String      @unique @db.VarChar(255)
  status       String      @default("A") @db.VarChar(50)
  gender       String?     @db.VarChar(255)
  tel          String?     @db.VarChar(255)
  email        String?     @db.VarChar(255)
  empimg       String?     @db.VarChar(255)
  posId        Int?
  position     Position?   @relation(fields: [posId], references: [id])
  departmentId Int?
  department   Department? @relation(fields: [departmentId], references: [id])
  divisionId   Int?
  division     Division?   @relation(fields: [divisionId], references: [id])
  officeId     Int?
  office       Office?     @relation(fields: [officeId], references: [id])
  unitId       Int?
  unit         Unit?       @relation(fields: [unitId], references: [id])
  createdAt    DateTime    @default(now()) @db.Timestamptz(0)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(0)
  user         User?
}

model Department {
  id                Int        @id
  department_name   String?    @db.VarChar(255)
  department_code   String?    @db.VarChar(50)
  department_status String     @default("A") @db.VarChar(50)
  divisions         Division[]
  employees         Employee[]
}

model Division {
  id              Int        @id
  division_name   String?    @db.VarChar(255)
  division_code   String?    @db.VarChar(50)
  division_status String     @default("A") @db.VarChar(50)
  branch_id       Int?
  short_name      String?    @db.VarChar(255)
  insur_code      String?    @db.VarChar(255)
  departmentId    Int
  department      Department @relation(fields: [departmentId], references: [id])
  offices         Office[]
  units           Unit[]
  employees       Employee[]
}

model Office {
  id            Int        @id
  office_name   String?    @db.VarChar(255)
  office_code   String?    @db.VarChar(50)
  office_status String     @default("A") @db.VarChar(50)
  divisionId    Int?
  division      Division?  @relation(fields: [divisionId], references: [id])
  units         Unit[]
  employees     Employee[]
}

model Unit {
  id          Int        @id
  unit_name   String?    @db.VarChar(255)
  unit_code   String?    @db.VarChar(50)
  unit_status String     @default("A") @db.VarChar(50)
  unit_type   String?    @db.VarChar(50)
  divisionId  Int?
  division    Division?  @relation(fields: [divisionId], references: [id])
  officeId    Int?
  office      Office?    @relation(fields: [officeId], references: [id])
  employees   Employee[]
}

model PositionGroup {
  id             Int            @id
  pos_group_name String         @db.VarChar(255)
  positioncodes  PositionCode[]
}

model PositionCode {
  id              Int            @id
  pos_code_name   String         @db.VarChar(255)
  pos_code_status String         @default("A") @db.VarChar(50)
  posgroupId      Int?
  positiongroup   PositionGroup? @relation(fields: [posgroupId], references: [id])
  positions       Position[]
}

model Position {
  id           Int           @id
  pos_name     String        @db.VarChar(255)
  pos_status   String        @default("A") @db.VarChar(50)
  poscodeId    Int?
  positioncode PositionCode? @relation(fields: [poscodeId], references: [id])
  employees    Employee[]
}

model Province {
  id             Int             @id
  province_name  String          @db.VarChar(255)
  province_code  String          @unique @db.VarChar(255)
  province_short String          @db.VarChar(50)
  branch_code    String          @db.VarChar(50)
  districts      District[]
  users          User[]
  turnoffDocs    TurnoffDoc[]
  emergencyDocs  EmergencyDoc[]
  cutpowerDocs   CutpowerDoc[]
  registerMeters RegisterMeter[]
}

model District {
  id             Int             @id
  provinceCode   String
  province       Province        @relation(fields: [provinceCode], references: [province_code])
  district_name  String          @db.VarChar(255)
  district_code  String          @unique @db.VarChar(50)
  villages       Village[]
  users          User[]
  turnoffDocs    TurnoffDoc[]
  emergencyDocs  EmergencyDoc[]
  cutpowerDocs   CutpowerDoc[]
  registerMeters RegisterMeter[]
}

model Village {
  id                 Int                @id
  districtCode       String
  district           District           @relation(fields: [districtCode], references: [district_code])
  village_name       String             @db.VarChar(255)
  village_code       String?            @db.VarChar(50)
  turnoffAddresses   TurnoffAddress[]
  emergencyAddresses EmergencyAddress[]
  cutpowerAddresses  CutpowerAddress[]
  registerMeters     RegisterMeter[]
}

model TurnoffDoc {
  id               Int              @id @default(autoincrement())
  title            String           @db.VarChar(255)
  description      String?          @db.Text
  startDate        DateTime         @db.Timestamptz(0)
  endDate          DateTime         @db.Timestamptz(0)
  startTime        String?          @db.VarChar(50)
  endTime          String?          @db.VarChar(50)
  turnoffFile      String           @db.VarChar(255)
  provinceId       Int?
  province         Province?        @relation(fields: [provinceId], references: [id])
  districtId       Int?
  district         District?        @relation(fields: [districtId], references: [id])
  createdById      Int
  createdBy        User             @relation(fields: [createdById], references: [id])
  createdAt        DateTime         @default(now()) @db.Timestamptz(0)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(0)
  turnoffAddresses TurnoffAddress[]
  turnoffAssigns   TurnoffAssign[]

  @@index([createdById])
  @@index([provinceId])
  @@index([districtId])
}

model TurnoffAddress {
  id        Int        @id @default(autoincrement())
  turnoffId Int
  turnoff   TurnoffDoc @relation(fields: [turnoffId], references: [id])
  villageId Int
  village   Village    @relation(fields: [villageId], references: [id])
  createdAt DateTime   @default(now()) @db.Timestamptz(0)
  updatedAt DateTime   @updatedAt @db.Timestamptz(0)

  @@index([turnoffId])
}

model TurnoffAssign {
  id        Int        @id @default(autoincrement())
  turnoffId Int
  turnoff   TurnoffDoc @relation(fields: [turnoffId], references: [id])
  userAppId Int
  docview   Boolean    @default(false) // true = view , false = pending
  createdAt DateTime   @default(now()) @db.Timestamptz(0)
  updatedAt DateTime   @updatedAt @db.Timestamptz(0)

  @@index([turnoffId])
  @@index([userAppId])
}

model EmergencyDoc {
  id                 Int                @id @default(autoincrement())
  title              String             @db.VarChar(255)
  description        String?            @db.Text
  emergencyDate      DateTime           @db.Timestamptz(0)
  startTime          String?            @db.VarChar(50)
  endTime            String?            @db.VarChar(50)
  lat                Float
  lng                Float
  emergencyImg       String?            @db.VarChar(255)
  provinceId         Int?
  province           Province?          @relation(fields: [provinceId], references: [id])
  districtId         Int?
  district           District?          @relation(fields: [districtId], references: [id])
  createdById        Int
  createdBy          User               @relation(fields: [createdById], references: [id])
  createdAt          DateTime           @default(now()) @db.Timestamptz(0)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(0)
  emergencyAddresses EmergencyAddress[]
  emergencyAssigns   EmergencyAssign[]

  @@index([createdById])
  @@index([provinceId])
  @@index([districtId])
}

model EmergencyAddress {
  id          Int          @id @default(autoincrement())
  emergencyId Int
  emergency   EmergencyDoc @relation(fields: [emergencyId], references: [id])
  villageId   Int
  village     Village      @relation(fields: [villageId], references: [id])
  createdAt   DateTime     @default(now()) @db.Timestamptz(0)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(0)

  @@index([emergencyId])
}

model EmergencyAssign {
  id          Int          @id @default(autoincrement())
  emergencyId Int
  emergency   EmergencyDoc @relation(fields: [emergencyId], references: [id])
  userAppId   Int
  docview     Boolean      @default(false) // true = view , false = pending
  createdAt   DateTime     @default(now()) @db.Timestamptz(0)
  updatedAt   DateTime     @updatedAt @db.Timestamptz(0)

  @@index([emergencyId])
  @@index([userAppId])
}

model CutpowerDoc {
  id                Int               @id @default(autoincrement())
  title             String            @db.VarChar(255)
  description       String?           @db.Text
  cutpowerDate      DateTime          @db.Timestamptz(0)
  cutpowerFile      String            @db.VarChar(255)
  provinceId        Int?
  province          Province?         @relation(fields: [provinceId], references: [id])
  districtId        Int?
  district          District?         @relation(fields: [districtId], references: [id])
  createdById       Int
  createdBy         User              @relation(fields: [createdById], references: [id])
  createdAt         DateTime          @default(now()) @db.Timestamptz(0)
  updatedAt         DateTime          @updatedAt @db.Timestamptz(0)
  cutpowerAddresses CutpowerAddress[]
  cutpowerAssigns   CutpowerAssign[]

  @@index([createdById])
  @@index([provinceId])
  @@index([districtId])
}

model CutpowerAddress {
  id         Int         @id @default(autoincrement())
  cutpowerId Int
  cutpower   CutpowerDoc @relation(fields: [cutpowerId], references: [id])
  villageId  Int
  village    Village     @relation(fields: [villageId], references: [id])
  createdAt  DateTime    @default(now()) @db.Timestamptz(0)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(0)

  @@index([cutpowerId])
}

model CutpowerAssign {
  id         Int         @id @default(autoincrement())
  cutpowerId Int
  cutpower   CutpowerDoc @relation(fields: [cutpowerId], references: [id])
  userAppId  Int
  docview    Boolean     @default(false) // true = view , false = pending
  createdAt  DateTime    @default(now()) @db.Timestamptz(0)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(0)

  @@index([cutpowerId])
  @@index([userAppId])
}

model SourceType {
  id             Int             @id @default(autoincrement())
  name           String          @db.VarChar(255)
  description    String?         @db.VarChar(255)
  registerMeters RegisterMeter[]
}

model MeterStatus {
  id             Int             @id @default(autoincrement())
  edlapp         String?         @db.VarChar(255)
  callcenter     String?         @db.VarChar(255)
  registerMeters RegisterMeter[]
}

model RegisterMeter {
  id               Int              @id @default(autoincrement())
  fullName         String           @db.VarChar(255)
  phone            String           @db.VarChar(255)
  accountNear      String           @db.VarChar(255)
  billNearImg      String?          @db.VarChar(255)
  idcardImg        String?          @db.VarChar(255)
  lat              Float?
  lng              Float?
  provinceId       Int
  province         Province         @relation(fields: [provinceId], references: [id])
  districtId       Int
  district         District         @relation(fields: [districtId], references: [id])
  villageId        Int
  village          Village          @relation(fields: [villageId], references: [id])
  meterStatusId    Int
  meterStatus      MeterStatus      @relation(fields: [meterStatusId], references: [id])
  sourcetypeId     Int
  sourcetype       SourceType       @relation(fields: [sourcetypeId], references: [id])
  createdById      Int
  createdAt        DateTime         @default(now()) @db.Timestamptz(0)
  updatedAt        DateTime         @updatedAt @db.Timestamptz(0)
  userAcceptMeters UserAcceptMeter?
}

model UserAcceptMeter {
  id             Int           @id @default(autoincrement())
  meterId        Int           @unique
  meter          RegisterMeter @relation(fields: [meterId], references: [id])
  userCallId     Int?
  userCall       User?         @relation("userCall", fields: [userCallId], references: [id])
  userProvinceId Int?
  userProvince   User?         @relation("userProvince", fields: [userProvinceId], references: [id])
  createdAt      DateTime      @default(now()) @db.Timestamptz(0)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(0)
}

model Topic {
  id            Int            @id @default(autoincrement())
  name          String         @db.VarChar(255)
  description   String?        @db.Text
  actived       Boolean        @default(true)
  createdById   Int
  createdBy     User           @relation(fields: [createdById], references: [id])
  createdAt     DateTime       @default(now()) @db.Timestamptz(0)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(0)
  conversations Conversation[]
}

model Conversation {
  id                  Int          @id @default(autoincrement())
  externalUserId      Int
  externalUser        ExternalUser @relation(fields: [externalUserId], references: [id])
  topicId             Int
  topic               Topic        @relation(fields: [topicId], references: [id])
  lastMessage         String?      @db.Text
  lastMessageAt       DateTime?    @db.Timestamptz(0)
  unreadExternalCount Int          @default(0)
  unreadAgentCount    Int          @default(0)
  createdAt           DateTime     @default(now()) @db.Timestamptz(0)
  updatedAt           DateTime     @updatedAt @db.Timestamptz(0)
  messages            Message[]

  @@unique([externalUserId, topicId])
  @@index([externalUserId])
  @@index([topicId])
}

enum SenderType {
  edlapp
  callcenter
}

enum MessageStatus {
  sent
  delivered
  seen
}

enum MessageType {
  text
  image
  audio
  location
}

model Message {
  id             Int           @id @default(autoincrement())
  conversationId Int
  conversation   Conversation  @relation(fields: [conversationId], references: [id])
  senderType     SenderType
  edlappId       Int? // mobile app
  edlappUser     ExternalUser? @relation(fields: [edlappId], references: [id])
  agentId        Int? // call center
  agentUser      User?         @relation(fields: [agentId], references: [id])
  mType          MessageType   @default(text)
  content        String?       @db.Text
  fileImg        String?       @db.VarChar(255)
  fileAudio      String?       @db.VarChar(255)
  lat            Float?
  lng            Float?
  status         MessageStatus @default(sent)
  seenAt         DateTime?     @db.Timestamptz(0)
  createdAt      DateTime      @default(now()) @db.Timestamptz(0)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(0)

  @@index([conversationId, createdAt])
}
